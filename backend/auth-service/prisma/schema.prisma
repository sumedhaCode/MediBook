generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("patient")

  appointments Appointment[]
  doctor       Doctor?
  slotFreezes  SlotFreeze[]
}

model Doctor {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  name         String
  specialty    String
  experience   Int
  location     String
  consultation Int
  rating       Float   @default(4.5)
  available    Boolean @default(true)
  isActive     Boolean @default(true)

  user         User           @relation(fields: [userId], references: [id])
  appointments Appointment[]
  availability Availability[]
  slotFreezes  SlotFreeze[]
}

model Appointment {
  id       Int    @id @default(autoincrement())
  userId   Int
  doctorId Int
  date     String
  time     String
  status   String @default("pending")

  user   User   @relation(fields: [userId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, date, time], name: "unique_doctor_slot_booking")
  @@index([userId])
  @@index([doctorId])
}

model Availability {
  id        Int     @id @default(autoincrement())
  doctorId  Int
  date      String
  time      String
  available Boolean @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, date, time], name: "unique_doctor_slot_availability")
  @@index([doctorId])
}

model SlotFreeze {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      String
  time      String
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, date, time], name: "unique_doctor_slot_freeze")
  @@index([userId])
  @@index([doctorId])
  @@index([expiresAt])
}
